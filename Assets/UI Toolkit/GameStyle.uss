.game-ui-root {
    flex-grow: 1;
    align-items: center;
    padding-top: 16px;
}

.run-timer-container {
    width: 120px;
}

.run-timer-label {
    width: 100%;
    color: rgb(255, 255, 255);
    font-size: 24px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    background-color: rgba(0, 0, 0, 0.55);
    border-radius: 6px;
    padding: 6px 12px;
}
